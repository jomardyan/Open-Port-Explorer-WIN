<Window x:Class="Open_Port_Explorer_WIN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Open_Port_Explorer_WIN"
        mc:Ignorable="d"
        Title="Open Port Explorer" 
        Height="860" Width="1500"
        MinHeight="720" MinWidth="1280"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryBrushHover" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryBrushPressed" Color="#1E40AF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerBrushHover" Color="#B91C1C"/>
        <SolidColorBrush x:Key="DangerBrushPressed" Color="#991B1B"/>
        <SolidColorBrush x:Key="StatusBarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AdminBarBrush" Color="#FEF3C7"/>
        <SolidColorBrush x:Key="AdminBorderBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AdminTextBrush" Color="#92400E"/>
        <SolidColorBrush x:Key="CardBlueBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="CardGreenBrush" Color="#DCFCE7"/>
        <SolidColorBrush x:Key="CardAmberBrush" Color="#FEF3C7"/>
        <SolidColorBrush x:Key="CardRedBrush" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="CardIndigoBrush" Color="#E0E7FF"/>

        <Style TargetType="Border" x:Key="SurfacePanelStyle">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SoftBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryBrushHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryBrushPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DangerBrushHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DangerBrushPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SoftBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SoftBorderBrush}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RuleStatus}" Value="Blocked">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RuleStatus}" Value="Trusted">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWatched}" Value="True">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSuspicious}" Value="True">
                    <Setter Property="Background" Value="#FFE4D6"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.95"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource SurfaceBrush}"
              Foreground="{DynamicResource PrimaryTextBrush}"
              BorderBrush="{DynamicResource SoftBorderBrush}"
              BorderThickness="0,0,0,1"
              Padding="4,2">
            <MenuItem Header="_File" Padding="8,6">
                <MenuItem Header="Refresh" Click="MenuRefresh_Click" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="Export CSV..." Click="MenuExportCsv_Click"/>
                <MenuItem Header="Export JSON..." Click="MenuExportJson_Click"/>
                <MenuItem Header="Export Activity Log..." Click="MenuExportHistory_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Actions" Padding="8,6">
                <MenuItem Header="Watch Selected" Click="MenuWatchSelected_Click"/>
                <MenuItem Header="Trust Selected" Click="MenuTrustSelected_Click"/>
                <MenuItem Header="Block Selected" Click="MenuBlockSelected_Click"/>
                <Separator/>
                <MenuItem Header="End Selected Process" Click="MenuEndProcess_Click"/>
                <MenuItem Header="Open File Location" Click="MenuOpenFileLocation_Click"/>
                <MenuItem Header="Copy Selected Row" Click="MenuCopyRow_Click"/>
            </MenuItem>
            <MenuItem Header="_View" Padding="8,6">
                <MenuItem Header="Reset Filters" Click="MenuResetFilters_Click" InputGestureText="Ctrl+R"/>
                <MenuItem Header="Toggle Theme" Click="ThemeButton_Click"/>
                <Separator/>
                <MenuItem Header="Set Snapshot Baseline" Click="MenuSetBaseline_Click"/>
                <MenuItem Header="Compare with Baseline" Click="MenuCompareBaseline_Click"/>
            </MenuItem>
            <MenuItem Header="_Help" Padding="8,6">
                <MenuItem Header="About" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AdminBarBrush}"
                BorderBrush="{DynamicResource AdminBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="ADMIN" Foreground="{DynamicResource AdminTextBrush}" Margin="0,0,8,0" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Name="AdminStatusTextBlock" Text="Checking permissions..." Foreground="{DynamicResource AdminTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Name="RequestAdminButton"
                        DockPanel.Dock="Right"
                        Content="Run as administrator"
                        Click="RequestAdminButton_Click"
                        Background="#D97706"
                        Margin="12,0,0,0"
                        Visibility="Collapsed"/>
            </DockPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource StatusBarBrush}"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   BorderBrush="{DynamicResource SoftBorderBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="8,4">
            <StatusBarItem>
                <TextBlock Name="LastRefreshTextBlock" Text="Last refresh: never" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Name="AlertTextBlock" Text="No changes detected" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Name="StatsTextBlock" Text="Listening: 0 | Established: 0 | Flagged: 0 | Watched: 0" Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Name="CountTextBlock" Text="Rows: 0" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Background="{DynamicResource CardBlueBrush}" Margin="0,0,12,0" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Current Rows" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Name="CurrentRowsCardTextBlock" Text="0" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SurfacePanelStyle}" Background="{DynamicResource CardGreenBrush}" Margin="0,0,12,0" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Listening Ports" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Name="ListeningCardTextBlock" Text="0" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SurfacePanelStyle}" Background="{DynamicResource CardIndigoBrush}" Margin="0,0,12,0" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Established" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Name="EstablishedCardTextBlock" Text="0" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource SurfacePanelStyle}" Background="{DynamicResource CardRedBrush}" Margin="0,0,12,0" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Flagged Items" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Name="FlaggedCardTextBlock" Text="0" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource SurfacePanelStyle}" Background="{DynamicResource CardAmberBrush}" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Watchlist Hits" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Name="WatchlistCardTextBlock" Text="0" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Padding="16" Margin="0,0,0,16" BorderBrush="#334155" BorderThickness="1" CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1E293B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                        <Button Name="RefreshButton" Content="Refresh Now" Click="RefreshButton_Click" ToolTip="Refresh immediately (F5)" Margin="0,0,14,8"/>

                        <CheckBox Name="AutoRefreshCheckBox"
                                  Content="Auto Refresh"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,8"
                                  IsChecked="True"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  Checked="AutoRefreshCheckBox_Changed"
                                  Unchecked="AutoRefreshCheckBox_Changed"/>

                        <CheckBox Name="SuspiciousOnlyCheckBox"
                                  Content="Suspicious Only"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,8"
                                  Foreground="#FECACA"
                                  FontWeight="SemiBold"
                                  Checked="Filters_SelectionChanged"
                                  Unchecked="Filters_SelectionChanged"/>

                        <CheckBox Name="WatchlistOnlyCheckBox"
                                  Content="Watchlist Only"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,8"
                                  Foreground="#FDE68A"
                                  FontWeight="SemiBold"
                                  Checked="Filters_SelectionChanged"
                                  Unchecked="Filters_SelectionChanged"/>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Search" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <TextBox Name="SearchTextBox" Width="170" Height="34" Margin="0" TextChanged="SearchTextBox_TextChanged" ToolTip="Global search (Ctrl+F)"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Port" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <TextBox Name="PortFilterTextBox" Width="84" Height="34" Margin="0" TextChanged="SearchTextBox_TextChanged" ToolTip="Filter by port number"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Address" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <TextBox Name="AddressFilterTextBox" Width="150" Height="34" Margin="0" TextChanged="SearchTextBox_TextChanged" ToolTip="Filter by local or remote address"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Process" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <TextBox Name="ProcessFilterTextBox" Width="150" Height="34" Margin="0" TextChanged="SearchTextBox_TextChanged" ToolTip="Filter by process name"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="PID" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <TextBox Name="PidFilterTextBox" Width="90" Height="34" Margin="0" TextChanged="SearchTextBox_TextChanged" ToolTip="Filter by process ID"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,2,0,0">
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Protocol" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Name="ProtocolFilterComboBox" Width="100" Margin="0" SelectionChanged="Filters_SelectionChanged">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                                <ComboBoxItem Content="TCP"/>
                                <ComboBoxItem Content="UDP"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="IP Family" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Name="FamilyFilterComboBox" Width="100" Margin="0" SelectionChanged="Filters_SelectionChanged">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                                <ComboBoxItem Content="IPv4"/>
                                <ComboBoxItem Content="IPv6"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="State" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Name="StateFilterComboBox" Width="145" Margin="0" SelectionChanged="Filters_SelectionChanged">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                                <ComboBoxItem Content="LISTENING"/>
                                <ComboBoxItem Content="ESTABLISHED"/>
                                <ComboBoxItem Content="TIME_WAIT"/>
                                <ComboBoxItem Content="CLOSE_WAIT"/>
                                <ComboBoxItem Content="CLOSED"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Rule" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Name="RuleFilterComboBox" Width="120" Margin="0" SelectionChanged="Filters_SelectionChanged">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                                <ComboBoxItem Content="Unruled"/>
                                <ComboBoxItem Content="Watched"/>
                                <ComboBoxItem Content="Trusted"/>
                                <ComboBoxItem Content="Blocked"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Interval" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Name="IntervalComboBox" Width="110" Margin="0" SelectionChanged="IntervalComboBox_SelectionChanged">
                                <ComboBoxItem Content="1 sec"/>
                                <ComboBoxItem Content="2 sec"/>
                                <ComboBoxItem Content="5 sec" IsSelected="True"/>
                                <ComboBoxItem Content="10 sec"/>
                                <ComboBoxItem Content="30 sec"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Rule Target" Style="{StaticResource ToolbarLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Name="RuleTargetComboBox" Width="110" Margin="0">
                                <ComboBoxItem Content="Port" IsSelected="True"/>
                                <ComboBoxItem Content="Process"/>
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Grid.Row="2" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Button Name="ExportCsvButton" Content="CSV" Click="ExportCsvButton_Click" Margin="0,0,10,0"/>
                        <Button Name="ExportJsonButton" Content="JSON" Click="ExportJsonButton_Click" Margin="0,0,10,0"/>
                        <Button Name="WatchSelectedButton" Content="Watch" Click="WatchSelectedButton_Click" Margin="0,0,10,0"/>
                        <Button Name="TrustSelectedButton" Content="Trust" Click="TrustSelectedButton_Click" Margin="0,0,10,0"/>
                        <Button Name="BlockSelectedButton" Content="Block" Style="{StaticResource DangerButtonStyle}" Click="BlockSelectedButton_Click" Margin="0,0,10,0"/>
                        <Button Name="ThemeButton" Content="Switch to Dark" Click="ThemeButton_Click" Margin="0,0,10,0"/>
                        <Button Name="TerminateProcessButton" Content="End Process" Style="{StaticResource DangerButtonStyle}" Click="TerminateProcessButton_Click" Margin="0"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SurfacePanelStyle}"
                        Padding="1"
                        ClipToBounds="True"
                        Margin="0,0,16,0">
                    <DataGrid Name="PortsDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              AlternatingRowBackground="#FAFAFA"
                              RowBackground="Transparent"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource SoftBorderBrush}"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeaderWidth="0"
                              BorderThickness="0"
                              Background="Transparent"
                              ClipboardCopyMode="IncludeHeader"
                              SelectionChanged="PortsDataGrid_SelectionChanged">

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Refresh" Click="MenuRefresh_Click"/>
                                <MenuItem Header="Watch Selected" Click="MenuWatchSelected_Click"/>
                                <MenuItem Header="Trust Selected" Click="MenuTrustSelected_Click"/>
                                <MenuItem Header="Block Selected" Click="MenuBlockSelected_Click"/>
                                <MenuItem Header="Copy Selected Row" Click="MenuCopyRow_Click"/>
                                <MenuItem Header="Open File Location" Click="MenuOpenFileLocation_Click"/>
                                <Separator/>
                                <MenuItem Header="End Selected Process" Click="MenuEndProcess_Click" Foreground="Red"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Port" Binding="{Binding PortNumber}" Width="72" SortMemberPath="PortNumber"/>
                            <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="100" SortMemberPath="ServiceName"/>
                            <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80" SortMemberPath="Protocol"/>
                            <DataGridTextColumn Header="IP" Binding="{Binding AddressFamily}" Width="70" SortMemberPath="AddressFamily"/>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" SortMemberPath="State"/>
                            <DataGridTextColumn Header="Rule" Binding="{Binding RuleStatus}" Width="90" SortMemberPath="RuleStatus"/>
                            <DataGridTextColumn Header="Local Address" Binding="{Binding LocalAddress}" Width="200" SortMemberPath="LocalAddress"/>
                            <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" Width="200" SortMemberPath="RemoteAddress"/>
                            <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70" SortMemberPath="ProcessId"/>
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="140" SortMemberPath="ProcessName"/>
                            <DataGridTextColumn Header="First Seen" Binding="{Binding FirstSeen, StringFormat={}{0:HH:mm:ss}}" Width="95" SortMemberPath="FirstSeen"/>
                            <DataGridTextColumn Header="Last Change" Binding="{Binding LastActivity, StringFormat={}{0:HH:mm:ss}}" Width="100" SortMemberPath="LastActivity"/>
                            <DataGridTextColumn Header="Observed" Binding="{Binding ObservedDuration}" Width="90" SortMemberPath="ObservedSeconds"/>
                            <DataGridCheckBoxColumn Header="Suspicious" Binding="{Binding IsSuspicious}" Width="90" SortMemberPath="IsSuspicious"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding SuspicionReason}" Width="240" SortMemberPath="SuspicionReason"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SurfacePanelStyle}" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Connection Details" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Service" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Name="DetailsServiceTextBlock" Text="Select a connection" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Text="Process" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Name="DetailsProcessTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="2" Text="Port Description" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Name="DetailsPortDescriptionTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="3" Text="Process Description" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Name="DetailsProcessDescriptionTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="4" Text="Process Path" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Name="DetailsProcessPathTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="5" Text="Protocol" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Name="DetailsProtocolTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="6" Text="Local" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Name="DetailsLocalTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="7" Text="Remote" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Name="DetailsRemoteTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="8" Text="Remote Host" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Name="DetailsRemoteHostTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="9" Text="Rule / Risk" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Name="DetailsRuleTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="10" Text="Observed" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Name="DetailsObservedTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="11" Text="Snapshot" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Name="DetailsSnapshotTextBlock" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource SurfacePanelStyle}" Padding="16">
                        <DockPanel>
                            <TextBlock Name="HistoryHeaderTextBlock"
                                       DockPanel.Dock="Top"
                                       Text="Recent Activity"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,0,0,12"/>
                            <ListBox Name="HistoryListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SoftBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold">
                                                    <Run Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{Binding EventType}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Details}" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
